@model AIPredictionHub.Models.Rainfall.RainfallViewModel

@{
    ViewData["Title"] = "Rainfall Prediction";
}

<div class="row mt-4 animate-fade-in">
    <div class="col-lg-5">
        <div class="glass-panel">
            <h2 class="fw-bold mb-4"><i class="fas fa-cloud-showers-heavy text-primary me-2"></i> Rainfall</h2>
            <p class="text-muted small mb-4">Input meteorological parameters to forecast precipitation levels using our trained ML model.</p>

            <form asp-action="Predict" method="post" id="predictionForm" onsubmit="showLoader()">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Temperature" class="form-label text-muted small text-uppercase fw-bold">Temperature (°C)</label>
                    <input asp-for="Input.Temperature" class="form-control" placeholder="e.g. 25.5" step="0.1" />
                    <span asp-validation-for="Input.Temperature" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Humidity" class="form-label text-muted small text-uppercase fw-bold">Humidity (%)</label>
                    <input asp-for="Input.Humidity" class="form-control" placeholder="e.g. 60" />
                    <span asp-validation-for="Input.Humidity" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.WindSpeed" class="form-label text-muted small text-uppercase fw-bold">Wind Speed (km/h)</label>
                    <input asp-for="Input.WindSpeed" class="form-control" placeholder="e.g. 15" />
                    <span asp-validation-for="Input.WindSpeed" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Pressure" class="form-label text-muted small text-uppercase fw-bold">Pressure (hPa)</label>
                    <input asp-for="Input.Pressure" class="form-control" placeholder="e.g. 1013" />
                    <span asp-validation-for="Input.Pressure" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="fas fa-magic me-2"></i> Predict
                    </button>
                    <button type="submit" formaction="/Rainfall/Reset" class="btn btn-outline-light">
                        <i class="fas fa-undo"></i>
                    </button>
                </div>
            </form>

            <div id="loader" class="text-center mt-4" style="display:none;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted small">Analyzing data patterns...</p>
            </div>
        </div>
    </div>

    <div class="col-lg-7 prediction-side">
        @if (Model.IsPredicted && Model.Prediction != null)
        {
            <div class="h-100 d-flex flex-column gap-4">
                <div class="card bg-primary bg-opacity-10 border-primary border-opacity-25 p-4 flex-grow-1 d-flex flex-column justify-content-center text-center animate-fade-in">
                    <h5 class="text-primary text-uppercase fw-bold small mb-2">Prediction Result</h5>
                    <div class="display-1 fw-bold mb-2">@Model.Prediction?.PredictedRainfall<span class="fs-4 ms-2 text-muted">mm</span></div>
                    <p class="text-muted mb-0">Estimated rainfall based on current atmospheric conditions.</p>
                </div>

                <div class="glass-panel animate-fade-in" style="animation-delay: 0.1s">
                    <h6 class="text-muted text-uppercase fw-bold small mb-4"><i class="fas fa-chart-line me-2"></i> Model Performance</h6>
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="h3 fw-bold">@Model.Metrics?.R2</div>
                            <div class="text-muted extra-small">R² Score</div>
                        </div>
                        <div class="col-4 border-start border-end border-white border-opacity-10">
                            <div class="h3 fw-bold">@Model.Metrics?.MAE</div>
                            <div class="text-muted extra-small">MAE</div>
                        </div>
                        <div class="col-4">
                            <div class="h3 fw-bold">@Model.Metrics?.RMSE</div>
                            <div class="text-muted extra-small">RMSE</div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="h-100 d-flex align-items-center justify-content-center p-5 empty-state-box">
                <div class="text-center text-muted">
                    <i class="fas fa-arrow-left fa-3x mb-3 opacity-25"></i>
                    <h5 class="fw-bold">Ready to Predict</h5>
                    <p class="small">Fill in the data on the left to see results here.</p>
                </div>
            </div>
        }
    </div>
</div>

<script>
    function showLoader() {
        document.getElementById("loader").style.display = "block";
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}