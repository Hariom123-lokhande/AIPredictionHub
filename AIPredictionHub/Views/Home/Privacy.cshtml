@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="glass-panel mt-5 animate-fade-in">
    <h1 class="fw-bold mb-4"><i class="fas fa-shield-alt text-primary me-2"></i> @ViewData["Title"]</h1>
    <p class="text-muted">Use this page to detail your site's privacy policy. Your data security is our priority.</p>
    <hr class="border-white border-opacity-10 my-4" />
    <div class="text-muted">
        <p>At AIPredictionHub, we take your privacy seriously. All data processed through our machine learning models is encrypted and used only for the purpose of generating your predictions.</p>
        <p>We do not share your personal information or historical prediction data with third parties.</p>
    </div>
</div>
