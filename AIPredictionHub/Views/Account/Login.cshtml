@model AIPredictionHub.Models.LoginModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login - AI Prediction Hub";
}

<div class="auth-container animate-fade-in">
    <div class="glass-panel">
        <div class="auth-header">
            <h2>Welcome Back</h2>
            <p>Access your AI-powered insights</p>
        </div>
        
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-4">
                <label asp-for="Email" class="form-label text-muted small text-uppercase fw-bold">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="fas fa-envelope"></i></span>
                    <input asp-for="Email" class="form-control border-start-0" placeholder="name@example.com" type="email" required />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            
            <div class="mb-4">
                <label asp-for="Password" class="form-label text-muted small text-uppercase fw-bold">Password</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="fas fa-lock"></i></span>
                    <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="••••••••" required />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            
            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-primary btn-lg">
                    Sign In <i class="fas fa-arrow-right ms-2 small"></i>
                </button>
            </div>
            
            <div class="text-center mt-4">
                <p class="text-muted small">Don't have an account? <a asp-action="Register" class="text-primary fw-bold text-decoration-none">Create one for free</a></p>
            </div>
        </form>
    </div>
</div>
